msgctxt "Addon Summary"
msgid "Nintendo - Game Boy Advance (VBA-M)"
msgstr "Nintendo — Game Boy Advance (VBA-M)"

msgctxt "Addon Description"
msgid "VBA-M is a Nintendo Game Boy and Game Boy Advance emulator based on the official VisualBoyAdvance by Forgotten and the VBA development team."
msgstr "VBA-M — это эмулятор Nintendo Game Boy и Game Boy Advance, основанный на официальном VisualBoyAdvance от Forgotten и команды разработчиков VBA."

msgctxt "#30001"
msgid "Use Official BIOS (If Available)"
msgstr "Использовать официальный BIOS (если доступен)"

msgctxt "#30002"
msgid "Force-Enable RTC"
msgstr "Принудительно включить RTC"

